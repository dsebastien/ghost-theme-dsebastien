{{!--
    Shared body for the 7 pillar hubs (articles-page-overhaul Tier 2.1).
    Rendered by the thin src/pillar-<slug>.hbs wrappers, each of which is the
    `template` of a /pillars/<slug>/ channel in configuration/routes.yaml.

    Why wrappers instead of one template + `data: tag.<slug>`: pillar tags are
    INTERNAL (visibility:internal) and Ghost's routes `data` resolver uses the
    Content API, which excludes internal tags — so `data: tag.hash-pillar-*`
    resolves to nothing and Ghost 404s the whole route. Passing identity via
    partial params sidesteps that entirely.

    Params (all from the wrapper):
    * pillarName   — display name, e.g. "PKM Foundations"
    * pillarEmoji  — leading emoji
    * pillarIntro  — hero intro paragraph
    * pillarSlug   — url segment, e.g. "pkm-foundations" (RSS link + offer switch)
    * bestFilter   — NQL for the "Start with the best" strip, e.g.
                     "tag:hash-pillar-pkm-foundations+featured:true+tag:blog"
--}}
{{#contentFor "meta_description"}}
<meta name="description" content="{{pillarIntro}}">
{{/contentFor}}

<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "{{pillarName}}",
    "description": "{{pillarIntro}}",
    "isPartOf": { "@type": "WebSite", "name": "{{@site.title}}", "url": "{{@site.url}}" },
    "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{@site.url}}" },
            { "@type": "ListItem", "position": 2, "name": "Articles", "item": "{{@site.url}}/blog/" },
            { "@type": "ListItem", "position": 3, "name": "{{pillarName}}" }
        ]
    }
}
</script>

<main class="gh-main pillar-page">

    <!-- Editorial hero -->
    <section class="gh-outer pillar-hero">
        <div class="gh-inner">
            <p class="pillar-kicker"><a href="/blog/">Articles</a> <span aria-hidden="true">›</span> Pillar</p>
            <h1 class="pillar-title is-title">{{pillarEmoji}} {{pillarName}}</h1>
            {{#if pillarIntro}}
                <p class="pillar-intro is-body">{{pillarIntro}}</p>
            {{/if}}
            <p class="pillar-hero-actions">
                <a class="top-link" href="/pillars/{{pillarSlug}}/rss/">Subscribe via RSS 📡</a>
                <span class="pillar-dot" aria-hidden="true">·</span>
                <a class="top-link" href="/tags/">Browse all topics</a>
            </p>
        </div>
    </section>

    {{!-- Best of this pillar: featured articles first. Guarded so it only
         shows when there are picks. --}}
    {{#get "posts" filter=bestFilter include="tags" limit="3" as |picks|}}
        {{#if picks}}
            <section class="gh-container is-grid gh-outer pillar-best">
                <div class="gh-container-inner gh-inner">
                    <h2 class="gh-container-title">Start with the best</h2>
                    <div class="gh-feed">
                        {{#foreach picks}}
                            {{> "post-card" size="large" lazyLoad=true}}
                        {{/foreach}}
                    </div>
                </div>
            </section>
        {{/if}}
    {{/get}}

    <!-- All articles in this pillar (paginated channel feed) + sidebar -->
    <section class="gh-container is-grid has-sidebar gh-outer">
        <div class="gh-container-inner gh-inner">
            <main class="gh-main">
                <h2 class="gh-container-title">All articles in this pillar</h2>
                <div class="gh-feed mt-4">
                    {{#foreach posts}}
                        {{> "post-card" lazyLoad=true}}
                    {{/foreach}}
                    {{#unless posts}}
                        <p class="gh-news-empty">No articles here yet. Check back soon.</p>
                    {{/unless}}
                </div>
                {{pagination}}
            </main>

            {{> "components/sidebar" showFeatured=true}}
        </div>
    </section>

    <!-- Contextual offer for this pillar -->
    <section class="gh-outer pillar-offer-band">
        <div class="gh-inner">
            {{#match pillarSlug "creator-systems"}}
                {{> "components/offer-card" topic="creator-systems"
                    heading="Want AI to be a real thinking partner, not a gimmick?"
                    productEmoji="🤖" productName="AI Ghostwriter Guide"
                    productDesc="Make AI write like you — your voice, your context, your standards."
                    productUrl="https://store.dsebastien.net/product/ai-ghostwriter-guide"
                    productId="ai-ghostwriter-guide" productPrice="€49.99"
                    magnetName="Knowledge System Checklist"
                    magnetUrl="https://www.dsebastien.net/free-knowledge-management-system-checklist"}}
            {{else match pillarSlug "content-systems"}}
                {{> "components/offer-card" topic="content-systems"
                    heading="Want to create content more consistently?"
                    productEmoji="🤖" productName="AI Ghostwriter Guide"
                    productDesc="Turn your knowledge into publish-ready content, in your own voice."
                    productUrl="https://store.dsebastien.net/product/ai-ghostwriter-guide"
                    productId="ai-ghostwriter-guide" productPrice="€49.99"
                    magnetName="Knowledge System Checklist"
                    magnetUrl="https://www.dsebastien.net/free-knowledge-management-system-checklist"}}
            {{else match pillarSlug "tools-and-systems"}}
                {{> "components/offer-card" topic="tools-and-systems"
                    heading="Ready to build a system that actually works?"
                    productEmoji="🚀" productName="Obsidian Starter Kit"
                    productDesc="Skip weeks of setup — ready-made vault, 40+ templates, proven structure, automation."
                    productUrl="https://store.dsebastien.net/product/obsidian-starter-kit"
                    productId="obsidian-starter-kit" productPrice="€199.99-€249.99"
                    magnetName="Beginner's Guide to Obsidian"
                    magnetUrl="https://www.dsebastien.net/free-beginners-guide-to-mastering-obsidian"}}
            {{else match pillarSlug "writing-and-thinking"}}
                {{> "components/offer-card" topic="writing-and-thinking"
                    heading="Want a note-taking practice that compounds?"
                    productEmoji="📓" productName="Journaling Deep Dive"
                    productDesc="Workshop on journaling, periodic reviews, and reflection routines."
                    productUrl="https://store.dsebastien.net/product/journaling-deep-dive"
                    productId="journaling-deep-dive" productPrice="€29.99"
                    magnetName="Knowledge System Checklist"
                    magnetUrl="https://www.dsebastien.net/free-knowledge-management-system-checklist"}}
            {{else match pillarSlug "pkm-foundations"}}
                {{> "components/offer-card" topic="pkm-foundations"
                    heading="Ready to build your knowledge system?"
                    productEmoji="📚" productName="Knowledge Management for Beginners"
                    productDesc="10+ hours of structured video lessons — from information chaos to a working system."
                    productUrl="https://knowledge-management-for-beginners.com"
                    productId="knowledge-management-for-beginners" productPrice="€69.99"
                    magnetName="Knowledge System Checklist"
                    magnetUrl="https://www.dsebastien.net/free-knowledge-management-system-checklist"}}
            {{else match pillarSlug "knowledge-work"}}
                {{> "components/offer-card" topic="knowledge-work"
                    heading="Ready to level up your knowledge work?"
                    productEmoji="💼" productName="Knowledge Worker Kit"
                    productDesc="Complete guides and systems for professional knowledge workers."
                    productUrl="https://store.dsebastien.net/product/knowledge-worker-kit"
                    productId="knowledge-worker-kit" productPrice="€249.99"
                    magnetName="Knowledge System Checklist"
                    magnetUrl="https://www.dsebastien.net/free-knowledge-management-system-checklist"}}
            {{else match pillarSlug "zen-productivity"}}
                {{> "components/offer-card" topic="zen-productivity"
                    heading="Ready to get properly organized?"
                    productEmoji="🗂️" productName="Personal Organization 101"
                    productDesc="Clarity, focus, and habits that stick — without the overwhelm."
                    productUrl="https://store.dsebastien.net/product/personal-organization-101"
                    productId="personal-organization-101" productPrice="€19.99"
                    magnetName="Knowledge System Checklist"
                    magnetUrl="https://www.dsebastien.net/free-knowledge-management-system-checklist"}}
            {{/match}}
        </div>
    </section>

    <!-- Explore the other pillars -->
    <section class="gh-outer pillar-related">
        <div class="gh-inner">
            <h2 class="gh-container-title">Explore the pillars</h2>
            <div class="pillar-related-grid">
                <a href="/pillars/pkm-foundations/" class="pillar-chip">📚 PKM Foundations</a>
                <a href="/pillars/tools-and-systems/" class="pillar-chip">🛠️ Tools &amp; Systems</a>
                <a href="/pillars/writing-and-thinking/" class="pillar-chip">🧠 Writing &amp; Thinking</a>
                <a href="/pillars/zen-productivity/" class="pillar-chip">🧭 Zen Productivity</a>
                <a href="/pillars/knowledge-work/" class="pillar-chip">💼 Knowledge Work</a>
                <a href="/pillars/content-systems/" class="pillar-chip">✍️ Content Systems</a>
                <a href="/pillars/creator-systems/" class="pillar-chip">🤖 AI &amp; Creator Systems</a>
            </div>
        </div>
    </section>

</main>
