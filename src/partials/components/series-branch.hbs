{{!--
    Series membership guard (Tier 2.5). Renders the series-strip ONLY when the
    current post belongs to `seriesTag`.

    Uses an id+tag intersection query instead of {{#has tag=}}: a scoped
    {{#get "posts" filter="id:<this>+tag:<internal>"}} reliably resolves
    internal-visibility tags (proven by pillar-body), whereas {{#has tag=}} does
    NOT match internal (`#`-prefixed) tags in this Ghost version — which is why
    the first cut rendered nothing even though the tags were applied.

    Params: seriesTag (hash-series-<slug>), seriesTitle. Inherits the post
    context, so {{id}} is the current post id.
--}}
{{#get "posts" filter="id:{{id}}+tag:{{seriesTag}}" limit="1" as |match|}}
    {{#if match.[0]}}
        {{> "components/series-strip" seriesTag=seriesTag seriesTitle=seriesTitle currentId=id}}
    {{/if}}
{{/get}}
