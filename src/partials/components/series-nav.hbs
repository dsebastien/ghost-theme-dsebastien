{{!--
    Series navigation dispatcher (articles plan Tier 2.5).

    One branch per series. Each branch is an inline membership guard:
      {{#get "posts" filter="id:{{id}}+tag:hash-series-<slug>" limit="1"}}
    which returns THIS post iff it carries the series's internal tag, then
    renders the shared series-strip.

    Why inline (not a partial, not {{#has}}):
      * {{#has tag="#..."}} does NOT match internal tags (Content API strips them
        from post.tags — verified live: post.tags came back empty).
      * A partial-param mustache in a filter (`filter="...{{seriesTag}}"`) does
        NOT interpolate. But a CONTEXT var does — `{{id}}` in a filter works
        (keep-reading.hbs uses `id:-{{id}}`). So the guard keeps the tag LITERAL
        and only interpolates `{{id}}`; series-strip gets the whole filter string
        as a param.

    Empty until the first series exists — renders nothing.

    CONTRACT (kept in sync by `developassion-publish` + src/data/series.json):
      * Adding a post to an EXISTING series needs ONLY the `#series-<slug>` tag.
      * A NEW series adds one branch here (+ one line in series.hbs), between the
        SERIES-BRANCHES markers.
--}}
{{!-- SERIES-BRANCHES:START — developassion-publish inserts new-series branches here --}}
{{#get "posts" filter="id:{{id}}+tag:hash-series-git-tutorial" limit="1" as |m|}}{{#if m.[0]}}{{> "components/series-strip" postsFilter="tag:hash-series-git-tutorial" seriesTitle="Git tutorial for beginners" currentId=id}}{{/if}}{{/get}}
{{#get "posts" filter="id:{{id}}+tag:hash-series-journaling" limit="1" as |m|}}{{#if m.[0]}}{{> "components/series-strip" postsFilter="tag:hash-series-journaling" seriesTitle="Journaling every day is powerful" currentId=id}}{{/if}}{{/get}}
{{#get "posts" filter="id:{{id}}+tag:hash-series-typescript" limit="1" as |m|}}{{#if m.[0]}}{{> "components/series-strip" postsFilter="tag:hash-series-typescript" seriesTitle="What's new in TypeScript" currentId=id}}{{/if}}{{/get}}
{{#get "posts" filter="id:{{id}}+tag:hash-series-team-management" limit="1" as |m|}}{{#if m.[0]}}{{> "components/series-strip" postsFilter="tag:hash-series-team-management" seriesTitle="Team management tips" currentId=id}}{{/if}}{{/get}}
{{#get "posts" filter="id:{{id}}+tag:hash-series-obsidian-deep-dives" limit="1" as |m|}}{{#if m.[0]}}{{> "components/series-strip" postsFilter="tag:hash-series-obsidian-deep-dives" seriesTitle="Obsidian deep dives" currentId=id}}{{/if}}{{/get}}
