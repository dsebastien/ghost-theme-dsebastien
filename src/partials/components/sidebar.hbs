{{!--
    Parameters:
    * showFeatured (true, false)
    * showCategories (true, false)
    * showRecommendations (true, false)
--}}
<aside class="gh-sidebar">
    <div class="gh-sidebar-inner">
        <section class="gh-about">
            {{#if @site.icon}}
                <img class="gh-about-icon" src="{{@site.icon}}" alt="{{@site.title}}" loading="lazy">
            {{/if}}
            <h3 class="gh-about-title is-title">{{@site.title}}</h3>
            {{#if @site.description}}
                <p class="gh-about-description is-body">{{@site.description}}</p>
            {{/if}}
                {{#if @site.members_enabled}}
                    {{#unless @member}}
                        <button class="gh-button" data-portal="signup">Subscribe</button>
                    {{else}}
                        {{#if @site.paid_members_enabled}}
                            {{#unless @member.paid}}
                                <button class="gh-button" data-portal="upgrade">Upgrade</button>
                            {{/unless}}
                        {{/if}}
                {{/unless}}
            {{/if}}
        </section>

        <!-- Featured -->
        {{#if showFeatured}}
            <section class="gh-recommendations">
                <h4 class="gh-sidebar-title">Featured</h4>
                <ul class="!list-none">
                    {{#get "posts" filter="featured:true" limit=5}}
                        {{#foreach posts}}
                            <li>➤&nbsp;<a href="{{url}}">
                                {{title}}
                            </a></li>
                        {{/foreach}}
                    {{/get}}
                    <li>➤&nbsp;<a href="/all-articles">All Articles</a></li>
                </ul>
            </section>
        {{/if}}

        <!-- Categories -->
        {{#if showCategories}}
            <section class="gh-recommendations">
                <h4 class="gh-sidebar-title">Categories</h4>
                <ul class="!list-none">
                    <li>➤&nbsp;<a href="/tag/personal-knowledge-management">Personal Knowledge Management</a></li>
                    <li>➤&nbsp;<a href="/tag/obsidian">Obsidian</a></li>
                    <li>➤&nbsp;<a href="/tag/knowledge-work">Knowledge Work</a></li>
                    <li>➤&nbsp;<a href="/tag/learning">Learning</a></li>
                    <li>➤&nbsp;<a href="/tag/personal-development">Personal Development</a></li>
                    <li>➤&nbsp;<a href="/tag/mental-health">Mental Health</a></li>
                    <li>➤&nbsp;<a href="/tag/productivity">Productivity</a></li>
                    <li>➤&nbsp;<a href="/tag/personal-organization">Personal Organization</a></li>
                    <li>➤&nbsp;<a href="/all-tags">All Tags</a></li>
                </ul>
            </section>
        {{/if}}

        <!-- Products -->
        <section class="sidebar-products">
            <h4 class="gh-sidebar-title">Go Further</h4>
            <a href="https://www.store.dsebastien.net/product/knowii-community" rel="noopener" class="sidebar-product-featured">
                <span class="sidebar-product-badge">MOST POPULAR</span>
                <strong class="sidebar-product-name">Knowii Community</strong>
                <span class="sidebar-product-desc">ALL courses + tools + community + future workshops</span>
                <span class="sidebar-product-cta">Learn more →</span>
            </a>
            <ul class="sidebar-product-list !list-none">
                <li><a href="https://store.dsebastien.net/product/obsidian-starter-kit" rel="noopener">🚀 Obsidian Starter Kit</a></li>
                <li><a href="https://knowledge-management-for-beginners.com" rel="noopener">📚 KM for Beginners</a></li>
                <li><a href="https://store.dsebastien.net/product/ai-ghostwriter-guide" rel="noopener">🤖 AI Ghostwriter Guide</a></li>
                <li><a href="https://store.dsebastien.net/product/pkm-coaching" rel="noopener">🦉 1-on-1 Coaching</a></li>
                <li><a href="https://store.dsebastien.net" rel="noopener">🛒 Browse all products</a></li>
            </ul>
        </section>

        <!-- Free Resources -->
        <section class="gh-recommendations">
            <h4 class="gh-sidebar-title">Free Resources</h4>
            <ul class="!list-none">
                <li>➤&nbsp;<a href="https://www.dsebastien.net/free-beginners-guide-to-mastering-obsidian">Beginner's Guide to Obsidian</a></li>
                <li>➤&nbsp;<a href="https://www.dsebastien.net/free-knowledge-management-system-checklist">Knowledge System Checklist</a></li>
                <li>➤&nbsp;<a href="https://www.dsebastien.net/free-pkm-tools-database">PKM Tools Database</a></li>
                <li>➤&nbsp;<a href="https://concepts.dsebastien.net">3,400+ Concepts &amp; Frameworks</a></li>
            </ul>
        </section>

        <!-- Recommendations -->
        {{#if showRecommendations}}
            <section class="gh-recommendations">
                <h4 class="gh-sidebar-title">Recommendations</h4>
                {{recommendations}}
                <button data-portal="recommendations">See all {{> "icons/arrow"}}</button>
            </section>
        {{/if}}
    </div>
</aside>