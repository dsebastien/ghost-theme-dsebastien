{{!--
    Slim sidebar: About + Featured + ONE product card (Knowii).
    Categories, the product list, and Free Resources moved to the footer —
    the sidebar must fit one viewport so its content is actually reachable
    (sticky elements never scroll internally). See
    documentation/plans/articles-page-overhaul.md (Tier 1.10).

    Parameters:
    * showFeatured (true, false)
--}}
<aside class="gh-sidebar">
    <div class="gh-sidebar-inner">
        <section class="gh-about">
            {{#if @site.icon}}
                <img class="gh-about-icon" src="{{@site.icon}}" alt="{{@site.title}}" loading="lazy">
            {{/if}}
            <h3 class="gh-about-title is-title">{{@site.title}}</h3>
            {{#if @site.description}}
                <p class="gh-about-description is-body">{{@site.description}}</p>
            {{/if}}
                {{#if @site.members_enabled}}
                    {{#unless @member}}
                        {{!-- data-subscribe-overlay opens the theme overlay; no data-portal on
                             purpose (Portal binds [data-portal] clicks) — the hash href stays
                             as the no-JS Portal fallback. See components/subscribe-overlay. --}}
                        <a class="gh-button" href="#/portal/signup" data-subscribe-overlay>Subscribe</a>
                    {{else}}
                        {{#if @site.paid_members_enabled}}
                            {{#unless @member.paid}}
                                <button class="gh-button" data-portal="upgrade">Upgrade</button>
                            {{/unless}}
                        {{/if}}
                {{/unless}}
            {{/if}}
        </section>

        <!-- One product card first (the priority CTA); everything else lives
             in the footer. Featured (a secondary link list) follows below. -->
        <section class="sidebar-products" data-cta-topic="sidebar">
            <h4 class="gh-sidebar-title">Go Further</h4>
            <a href="https://www.store.dsebastien.net/product/knowii-community" rel="noopener" class="sidebar-product-featured" data-cta="knowii">
                <span class="sidebar-product-badge">MOST POPULAR</span>
                <strong class="sidebar-product-name">Knowii Community</strong>
                <span class="sidebar-product-desc">ALL courses + tools + community + future workshops</span>
                <span class="sidebar-product-cta">Learn more →</span>
            </a>
        </section>

        <!-- Featured -->
        {{#if showFeatured}}
            <section class="gh-recommendations">
                <h4 class="gh-sidebar-title">Featured</h4>
                <ul class="!list-none">
                    {{#get "posts" filter="featured:true" limit=5}}
                        {{#foreach posts}}
                            <li>➤&nbsp;<a href="{{url}}">
                                {{title}}
                            </a></li>
                        {{/foreach}}
                    {{/get}}
                    <li>➤&nbsp;<a href="/all-articles/">All Articles</a></li>
                    <li>➤&nbsp;<a href="/tags/">All Topics</a></li>
                </ul>
            </section>
        {{/if}}
    </div>
</aside>
