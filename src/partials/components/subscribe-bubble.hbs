{{!--
    Floating subscribe bubble — the theme-owned replacement for Ghost Portal's
    launcher (hidden in Ghost Admin > Portal settings). Non-members only.
    Opens the subscribe overlay via [data-subscribe-overlay]; the Portal hash
    href stays as the fallback when this script failed but Portal loaded.
    Hidden on post pages: the sticky-cta bottom bar already covers subscribe there.
--}}
{{#unless @member}}
    <a id="subscribe-bubble" class="subscribe-bubble" href="#/portal/signup" data-subscribe-overlay aria-label="Subscribe to the newsletter">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        <span class="subscribe-bubble-label">Subscribe</span>
    </a>
{{/unless}}
