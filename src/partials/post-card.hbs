{{!--
    Card size variants (Tier 1.9): pass size="hero" | "large" | "regular" | "compact".
    Default (no size param) is regular — the historic card plus the Tier 1.9
    metadata upgrades: reading time in the footer (every non-compact size,
    site-wide) and a topic pill (hidden by default in CSS; surfaces opt in —
    see screen.css section 7.1).
    compact renders no feature image and shows the date only (no reading time).
    The topic pill uses tags.[1] — the FIRST TOPIC tag. tags.[0]/primary_tag is the
    content-TYPE marker (blog/newsletter/news), never a topic (see
    documentation/plans/articles-page-overhaul.md, Audit findings). Note that
    tags are only present in channel/collection contexts or when the
    surrounding {{#get}} passes include="tags".
--}}
<article class="gh-card gh-card-{{#if size}}{{size}}{{else}}regular{{/if}} {{post_class}}">
    <a class="gh-card-link" href="{{url}}">
        {{#match size "compact"}}{{else}}
            {{#if feature_image}}
                <figure class="gh-card-image">
                    <img
                        srcset="{{img_url feature_image size="xs" format="webp"}} 160w,
                                {{img_url feature_image size="s" format="webp"}} 320w,
                                {{img_url feature_image size="m" format="webp"}} 600w,
                                {{img_url feature_image size="l" format="webp"}} 960w,
                                {{img_url feature_image size="xl" format="webp"}} 1200w,
                                {{img_url feature_image size="xxl" format="webp"}} 2000w"
                        sizes="{{#if imageSizes}}{{imageSizes}}{{else}}320px{{/if}}"
                        src="{{img_url feature_image size="m"}}"
                        alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                        {{#if lazyLoad}}loading="lazy"{{/if}}
                    >
                </figure>
            {{/if}}
        {{/match}}
        <div class="gh-card-wrapper">
            {{#if tags.[1]}}
                <p class="gh-card-tag">{{tags.[1].name}}</p>
            {{/if}}
            <h3 class="gh-card-title is-title">{{title}}</h3>
            {{#if custom_excerpt}}
                <p class="gh-card-excerpt is-body">{{custom_excerpt}}</p>
            {{/if}}
            {{#unless custom_excerpt}}
                {{#if excerpt}}
                    <p class="gh-card-excerpt is-body">{{excerpt}}</p>
                {{/if}}
            {{/unless}}
            <footer class="gh-card-meta">
                {{#unless access}}
                    {{^has visibility="public"}}
                        {{> "icons/lock"}}
                    {{/has}}
                {{/unless}}<!--
             -->{{#if @custom.show_author}}
                    <span class="gh-card-author">{{{t "By {authors}" authors=(authors autolink="false" separator=", ") }}}</span>
                {{/if}}
                {{#if @custom.show_publish_date}}
                    <time class="gh-card-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
                {{/if}}
                {{#match size "compact"}}{{else}}
                    <span class="gh-card-reading-time">{{reading_time}}</span>
                {{/match}}<!--
         --></footer>
        </div>
    </a>
</article>
