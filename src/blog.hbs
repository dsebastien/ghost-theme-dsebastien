{{!< default}}
{{!-- The tag above means: insert everything in this file into the body of the default.hbs template --}}

{{!--
    Topic sections are rendered via partials/components/topic-section.hbs.
    Every section filter is scoped to tag:blog (the deliberate marker for the
    articles surface — newsletters/news/project pages share topic tags but must
    never appear here) and uses cascading tag:-[...] exclusions so each article
    appears in exactly ONE section (first match wins, ordered specific → general).
    Section set + counts audited against the live Content API on 2026-07-17 —
    see documentation/plans/articles-page-overhaul.md (Audit findings, Tier 1.0).
--}}

{{#contentFor "meta_description"}}
<meta name="description" content="Sébastien Dubois's blog. Articles on knowledge management, productivity, AI, and building systems that turn information into output.">
{{/contentFor}}

<main class="gh-main gh-outer blog">
    <section class="gh-inner !mt-32">
        <h1 class="gh-article-title is-title">Articles ✍️</h1>
        <p class="gh-article-excerpt">📡 <a class="top-link" href="/blog/rss/">Subscribe to the articles RSS feed</a> · <a class="top-link" href="/feeds/">browse all feeds</a>.</p>
    </section>

    {{!--
        Sticky topic nav: one pill per topic section anchor below. Sticks at the
        top of the viewport once scrolled (the site header is not sticky) and
        scrolls horizontally with a hidden scrollbar on small screens.
        Scroll-spy + smooth scrolling live in assets/js/blog-nav.js.
    --}}
    <nav id="blog-topic-nav" class="blog-topic-nav" aria-label="Article topics">
        <div class="gh-inner blog-topic-nav-inner">
            <a class="blog-topic-pill" href="#obsidian">Obsidian</a>
            <a class="blog-topic-pill" href="#ai">AI</a>
            <a class="blog-topic-pill" href="#personal-knowledge-management">Personal Knowledge Management</a>
            <a class="blog-topic-pill" href="#knowledge-work">Knowledge Work</a>
            <a class="blog-topic-pill" href="#productivity">Productivity &amp; Organization</a>
            <a class="blog-topic-pill" href="#learning">Learning</a>
            <a class="blog-topic-pill" href="#personal-development">Personal Development &amp; Mental Health</a>
            <a class="blog-topic-pill" href="#writing">Writing</a>
            <a class="blog-topic-pill" href="#software-development">Software Development</a>
            <a class="blog-topic-pill" href="#more">More</a>
        </div>
    </nav>

    <section class="gh-container is-grid has-sidebar gh-outer">
        <div class="gh-container-inner gh-inner">
            <main class="gh-main">
                {{!--
                    Hero zone (Tier 1.0): newest featured article as the hero card,
                    the next two featured as "Editor's picks" (large). Curation
                    lever = Ghost's featured flag (13 posts, all articles — audit).
                    include="tags" is required for the topic pill — {{#get}} does
                    not load tag relations by default. imageSizes matches the
                    full-width (hero) and half-width (large) grid slots.
                    Guards: {{#get}} renders its block even for empty results
                    ({{else}} only fires on API error), so the hero div and the
                    picks heading only render when there are posts to fill them.
                    Known + accepted: hero-zone articles also appear in their
                    topic section below (topic filters don't exclude featured,
                    because that would also hide the ~10 featured-but-not-in-hero
                    articles from topic sections).
                --}}
                {{#get "posts" filter="featured:true+tag:blog" include="tags" limit=3 as |featuredPosts|}}
                    {{#if featuredPosts}}
                        <div class="gh-feed blog-hero">
                            {{#foreach featuredPosts to="1"}}
                                {{> "post-card" size="hero" imageSizes="(max-width: 767px) 100vw, 960px"}}
                            {{/foreach}}
                            {{#if featuredPosts.[1]}}
                                <h2 class="section-title">Editor's picks</h2>
                                {{#foreach featuredPosts from="2"}}
                                    {{> "post-card" size="large" imageSizes="(max-width: 767px) 100vw, 480px"}}
                                {{/foreach}}
                            {{/if}}
                        </div>
                    {{/if}}
                {{/get}}

                {{!--
                    Latest: 5 newest non-featured articles. featured:false
                    guarantees no duplication with the hero zone above.
                --}}
                <h2 class="section-title">{{t "Latest"}}</h2>
                <div class="gh-feed mt-4">
                    {{#get "posts" filter="tag:blog+featured:false" include="tags" limit=5 as |latestPosts|}}
                        {{#foreach latestPosts}}
                            {{> "post-card" size="compact"}}
                        {{/foreach}}
                    {{/get}}

                    <div class="">
                        <a href="/all-articles/">See all articles {{> "icons/arrow"}}</a>
                        <hr class="!my-8"/>
                    </div>
                </div>

                {{> "components/topic-section"
                    title="Obsidian"
                    anchor="obsidian"
                    topicFilter="tag:blog+tag:obsidian"
                    seeAllUrl="/tag/obsidian"}}

                {{> "components/topic-section"
                    title="AI"
                    anchor="ai"
                    topicFilter="tag:blog+tag:[ai,ai-2,ai-skills,claude-code]+tag:-[obsidian]"
                    seeAllUrl="/feeds/ai/"}}

                {{!-- Inline capture after the second section (plan Tier 1.0 item 5) --}}
                {{#unless @member}}
                    {{> "components/lead-magnet-cta" email_field_id="blog-inline-email"}}
                {{/unless}}

                {{> "components/topic-section"
                    title="Personal Knowledge Management"
                    anchor="personal-knowledge-management"
                    topicFilter="tag:blog+tag:[personal-knowledge-management,note-taking]+tag:-[obsidian,ai,ai-2,ai-skills,claude-code]"
                    seeAllUrl="/tag/personal-knowledge-management"}}

                {{!-- Topic-matched offer band (listing context: explicit params) --}}
                {{> "components/offer-card" topic="pkm"
                    heading="Ready to build your knowledge system?"
                    productEmoji="📚" productName="Knowledge Management for Beginners"
                    productDesc="10+ hours of structured video lessons — from information chaos to a working system."
                    productUrl="https://knowledge-management-for-beginners.com"
                    productId="knowledge-management-for-beginners" productPrice="€69.99"
                    magnetName="Knowledge System Checklist"
                    magnetUrl="https://www.dsebastien.net/free-knowledge-management-system-checklist"}}

                {{> "components/topic-section"
                    title="Knowledge Work"
                    anchor="knowledge-work"
                    topicFilter="tag:blog+tag:knowledge-work+tag:-[obsidian,ai,ai-2,ai-skills,claude-code,personal-knowledge-management,note-taking]"
                    seeAllUrl="/tag/knowledge-work"}}

                <span id="personal-organization"></span>
                {{> "components/topic-section"
                    title="Productivity & Organization"
                    anchor="productivity"
                    topicFilter="tag:blog+tag:[productivity,personal-organization]+tag:-[obsidian,ai,ai-2,ai-skills,claude-code,personal-knowledge-management,note-taking,knowledge-work]"
                    seeAllUrl="/feeds/productivity/"}}

                {{> "components/topic-section"
                    title="Learning"
                    anchor="learning"
                    topicFilter="tag:blog+tag:learning+tag:-[obsidian,ai,ai-2,ai-skills,claude-code,personal-knowledge-management,note-taking,knowledge-work,productivity,personal-organization]"
                    seeAllUrl="/tag/learning"}}

                <span id="mental-health"></span>
                {{> "components/topic-section"
                    title="Personal Development & Mental Health"
                    anchor="personal-development"
                    topicFilter="tag:blog+tag:[personal-development,mental-health]+tag:-[obsidian,ai,ai-2,ai-skills,claude-code,personal-knowledge-management,note-taking,knowledge-work,productivity,personal-organization,learning]"
                    seeAllUrl="/tag/personal-development"}}

                {{> "components/topic-section"
                    title="Writing"
                    anchor="writing"
                    topicFilter="tag:blog+tag:writing+tag:-[obsidian,ai,ai-2,ai-skills,claude-code,personal-knowledge-management,note-taking,knowledge-work,productivity,personal-organization,learning,personal-development,mental-health]"
                    seeAllUrl="/tag/writing"}}

                {{> "components/topic-section"
                    title="Software Development"
                    anchor="software-development"
                    topicFilter="tag:blog+tag:[software-development,web-development]+tag:-[obsidian,ai,ai-2,ai-skills,claude-code,personal-knowledge-management,note-taking,knowledge-work,productivity,personal-organization,learning,personal-development,mental-health,writing]"
                    seeAllUrl="/feeds/dev/"}}

                {{!-- Closing offer band before the catch-all section --}}
                {{> "components/offer-card" topic="default"
                    heading="Tired of information overwhelm? Build a system that works:"
                    productEmoji="🎯" productName="Knowii Community"
                    productDesc="Community + courses + tools in one place — pick the tier that fits."
                    productUrl="https://www.store.dsebastien.net/product/knowii-community/"
                    productId="knowii-community" productPrice="From €14.99/quarter"
                    magnetName="Knowledge System Checklist"
                    magnetUrl="https://www.dsebastien.net/free-knowledge-management-system-checklist"
                    hideKnowii=true}}

                {{> "components/topic-section"
                    title="More Articles"
                    anchor="more"
                    topicFilter="tag:blog+tag:-[obsidian,ai,ai-2,ai-skills,claude-code,personal-knowledge-management,note-taking,knowledge-work,productivity,personal-organization,learning,personal-development,mental-health,writing,software-development,web-development]"
                    seeAllUrl="/all-articles/"}}
            </main>

            {{> "components/sidebar" showFeatured=true showCategories=true showRecommendations=true}}
        </div>
    </section>
</main>
