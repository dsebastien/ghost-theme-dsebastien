{{!< default}}
{{!-- The tag above means: insert everything in this file into the body of the default.hbs template --}}

{{#post}}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{@site.url}}"
        }{{#if primary_tag}},
        {
            "@type": "ListItem",
            "position": 2,
            "name": "{{primary_tag.name}}",
            "item": "{{primary_tag.url}}"
        },
        {
            "@type": "ListItem",
            "position": 3,
            "name": "{{title}}"
        }{{else}},
        {
            "@type": "ListItem",
            "position": 2,
            "name": "{{title}}"
        }{{/if}}
    ]
}
</script>

<main class="gh-main">

    <article class="gh-article {{post_class}}">

        <header class="gh-article-header gh-canvas">

            {{#if primary_tag}}
                <a class="gh-article-tag" href="{{primary_tag.url}}">{{primary_tag.name}}</a>
            {{/if}}
            <h1 class="gh-article-title is-title">{{title}}</h1>
            {{#if custom_excerpt}}
                <p class="gh-article-excerpt is-body">{{custom_excerpt}}</p>
            {{/if}}

            {{#if @custom.show_post_metadata}}
            <div class="gh-article-meta">
                <div class="gh-article-author-image instapaper_ignore">
                    {{#foreach authors}}
                        {{#if profile_image}}
                            <a href="{{url}}">
                                <img class="author-profile-image" src="{{img_url profile_image size="xs"}}" alt="{{name}}">
                            </a>
                        {{else}}
                            <a href="{{url}}">{{> "icons/avatar"}}</a>
                        {{/if}}
                    {{/foreach}}
                </div>
                <div class="gh-article-meta-wrapper">
                    <h4 class="gh-article-author-name">{{authors}}</h4>
                    <div class="gh-article-meta-content">
                        <time class="gh-article-meta-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
                        {{#if reading_time}}
                            <span class="gh-article-meta-length"><span class="bull">—</span> {{reading_time minute=(t "1 min read") minutes=(t "% min read")}}</span>
                        {{/if}}
                    </div>
                </div>
            </div>
            {{/if}}

            {{> "components/social-share"}}

            {{> "feature-image"}}

        </header>

        <section class="gh-content gh-canvas is-body{{#if @custom.enable_drop_caps_on_posts}} drop-cap{{/if}}">
            {{content}}

            {{!-- Mid-article CTA: hidden source, relocated by JS into the article body --}}
            {{#unless @member}}
            <aside id="mid-article-cta" class="mid-article-cta" hidden>
                <p class="mid-article-cta-text">Enjoying this? <strong>Subscribe for free</strong> to get articles like this every week.</p>
                <a class="gh-button mid-article-cta-button" href="#/portal/signup" data-portal="signup">Subscribe ✨</a>
            </aside>
            {{else}}
                {{#unless @member.paid}}
            <aside id="mid-article-cta" class="mid-article-cta" hidden>
                <p class="mid-article-cta-text">Want the full archive and community access? <strong>Upgrade your membership.</strong></p>
                <a class="gh-button mid-article-cta-button" href="#/portal/account/plans" data-portal="account/plans">Upgrade →</a>
            </aside>
                {{/unless}}
            {{/unless}}

            {{!-- Author Signature --}}
            <hr class="signature-divider" />

