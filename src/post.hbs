{{!< default}}
{{!-- The tag above means: insert everything in this file into the body of the default.hbs template --}}

{{#post}}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{@site.url}}"
        },
        {
            "@type": "ListItem",
            "position": 2,
            "name": "{{#match primary_tag.slug "newsletter"}}Newsletter{{else match primary_tag.slug "news"}}News{{else}}Articles{{/match}}",
            "item": "{{@site.url}}/{{#match primary_tag.slug "newsletter"}}newsletter{{else match primary_tag.slug "news"}}news{{else}}blog{{/match}}/"
        }{{#if tags.[1]}},
        {
            "@type": "ListItem",
            "position": 3,
            "name": "{{tags.[1].name}}",
            "item": "{{tags.[1].url}}"
        },
        {
            "@type": "ListItem",
            "position": 4,
            "name": "{{title}}"
        }{{else}},
        {
            "@type": "ListItem",
            "position": 3,
            "name": "{{title}}"
        }{{/if}}
    ]
}
</script>

{{!-- Enriched article schema (homepage-start-overhaul 4.2 / GEO). Supplements
     Ghost's generic auto-emitted Article (from {{ghost_head}}) with the fields it
     omits and — crucially — links the author to the ONE #person entity defined
     in default.hbs (added in 3.2), so every article's authority consolidates
     into a single graph node instead of a per-post orphan. publisher → the
     #organization node, isPartOf → #website. speakable points answer engines at
     the Key Takeaways box (4.1) + title. Two Article-ish nodes coexist on the
     page (harmless; ours is richer + @id-linked). {{title}}/{{name}} are
     HTML-escaped inside JSON here, matching the existing BreadcrumbList above. --}}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "@id": "{{url absolute="true"}}#article",
    "mainEntityOfPage": "{{url absolute="true"}}",
    "headline": "{{title}}",
    "url": "{{url absolute="true"}}",
    "datePublished": "{{date format="YYYY-MM-DDTHH:mm:ssZ"}}",
    "dateModified": "{{date updated_at format="YYYY-MM-DDTHH:mm:ssZ"}}",
    "inLanguage": "en",
    "author": { "@id": "https://www.dsebastien.net/#person" },
    "publisher": { "@id": "https://developassion.be/#organization" },
    "isPartOf": { "@id": "https://www.dsebastien.net/#website" },
    "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".article-tldr", ".gh-article-title"]
    }{{#if custom_excerpt}},
    "description": "{{custom_excerpt}}"{{/if}}{{#if feature_image}},
    "image": "{{img_url feature_image absolute="true"}}"{{/if}}{{#if primary_tag}},
    "articleSection": "{{primary_tag.name}}"{{/if}}{{#if tags}},
    "keywords": "{{#foreach tags}}{{name}}{{#unless @last}}, {{/unless}}{{/foreach}}"{{/if}}
}
</script>

<main class="gh-main">

    <article class="gh-article {{post_class}}">

        <header class="gh-article-header gh-canvas">

            {{#if primary_tag}}
                <a class="gh-article-tag" href="{{primary_tag.url}}">{{primary_tag.name}}</a>
            {{/if}}
            {{!-- Freshness badge (Tier 1.8): hidden; assets/js/freshness.js reveals it
                 only for genuine refreshes (updated_at ≥30 days after published AND after
                 the 2026-06 site-wide re-timestamp cutoff). --}}
            <span class="gh-article-freshness" hidden data-published="{{date format="X"}}" data-updated="{{date updated_at format="X"}}">↻ Updated {{date updated_at format="MMM YYYY"}}</span>
            <h1 class="gh-article-title is-title">{{title}}</h1>
            {{!-- Key Takeaways box (homepage-start-overhaul 4.1 / GEO): promote
                 custom_excerpt into a labeled, visually-distinct summary — the
                 self-contained chunk answer engines lift into AI Overviews.
                 Referenced by the speakable spec in the Article schema (4.2).
                 Graceful: renders nothing when custom_excerpt is empty. --}}
            {{#if custom_excerpt}}
                <aside class="article-tldr" aria-label="Key takeaways">
                    <span class="article-tldr-label">In short</span>
                    <p class="article-tldr-text is-body">{{custom_excerpt}}</p>
                </aside>
            {{/if}}

            {{#if @custom.show_post_metadata}}
            <div class="gh-article-meta">
                <div class="gh-article-author-image instapaper_ignore">
                    {{#foreach authors}}
                        {{#if profile_image}}
                            <a href="{{url}}">
                                <img class="author-profile-image" src="{{img_url profile_image size="xs"}}" alt="{{name}}">
                            </a>
                        {{else}}
                            <a href="{{url}}">{{> "icons/avatar"}}</a>
                        {{/if}}
                    {{/foreach}}
                </div>
                <div class="gh-article-meta-wrapper">
                    <h4 class="gh-article-author-name">{{authors}}</h4>
                    <div class="gh-article-meta-content">
                        <time class="gh-article-meta-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
                        <span class="gh-article-meta-updated" hidden><span class="bull">·</span> updated <time datetime="{{date updated_at format="YYYY-MM-DD"}}">{{date updated_at format="DD MMM YYYY"}}</time></span>
                        {{#if reading_time}}
                            <span class="gh-article-meta-length"><span class="bull">—</span> {{reading_time minute=(t "1 min read") minutes=(t "% min read")}}</span>
                        {{/if}}
                    </div>
                </div>
            </div>
            {{/if}}

            {{> "components/social-share"}}

            {{> "feature-image"}}

        </header>

        <section class="gh-content gh-canvas is-body{{#if @custom.enable_drop_caps_on_posts}} drop-cap{{/if}}">

            {{!-- Series wayfinding (Tier 2.5): if this post is part of a series,
                 show the ordered outline up top so a "landed on part 3" reader
                 sees the whole journey. Renders nothing when not in a series. --}}
            {{> "components/series-nav"}}

            {{!-- Curriculum wayfinding (homepage-start-overhaul 2.6): if this
                 post belongs to a pillar cluster, link into the matching guided
                 /start/ layer. In the content flow (not the desktop-only side
                 rail) so it renders on every viewport. Nothing for off-pillar
                 posts. --}}
            {{> "components/curriculum-cta"}}

            {{!-- Desktop-only side rail while reading (≥1300px): the slim
                 sidebar (About + Featured + Knowii). Hidden via CSS when the
                 post uses wide/full-width cards. Tier 1.10. --}}
            <div class="post-side-rail">
                {{> "components/sidebar" showFeatured=true}}
            </div>

            {{content}}

            {{!-- Mid-article CTA: hidden source, relocated by JS into the article body --}}
            {{#unless @member}}
            <aside id="mid-article-cta" class="mid-article-cta" hidden>
                <p class="mid-article-cta-text">Enjoying this? <strong>Subscribe for free</strong> to get articles like this every week.</p>
                <a class="gh-button mid-article-cta-button" href="#/portal/signup" data-subscribe-overlay>Subscribe ✨</a>
            </aside>
            {{else}}
                {{#unless @member.paid}}
            <aside id="mid-article-cta" class="mid-article-cta" hidden>
                <p class="mid-article-cta-text">Want the full archive and community access? <strong>Upgrade your membership.</strong></p>
                <a class="gh-button mid-article-cta-button" href="#/portal/account/plans" data-portal="account/plans">Upgrade →</a>
            </aside>
                {{/unless}}
            {{/unless}}

            {{!-- Scroll-triggered inline capture (Tier 2.4): hidden source,
                 relocated + revealed at ~60% scroll by assets/js/engagement.js.
                 Logged-out only — the topic-matched free lead magnet. --}}
            {{#unless @member}}
                {{> "components/scroll-capture"}}
            {{/unless}}

            {{!-- Keep reading: topical loop BEFORE any product signature (Tier 1.4) --}}
            {{> "components/keep-reading"}}

            {{!-- Author Signature --}}
            <hr class="signature-divider" />

            <h2 id="about-sebastien">About Sébastien</h2>
            {{> "components/author-card"}}

            <h2 id="ready-to-get-to-the-next-level">Ready to get to the next level?</h2>
            {{> "components/contextual-offer"}}

            <div class="post-end-share">
                <p><strong>Found this valuable?</strong> Share it with someone who needs it.</p>
                {{> "components/social-share"}}
            </div>
        </section>
    </article>

    {{#if comments}}
        <div class="gh-comments gh-canvas">
            {{comments}}
        </div>
    {{/if}}

    {{> "components/sticky-cta"}}

</main>

{{/post}}


{{#get "posts" include="authors" filter="tag:{{primary_tag.slug}}+id:-{{post.id}}" limit="4" as |next|}}
    {{#if next}}
        <section class="gh-container is-grid gh-outer">
            <div class="gh-container-inner gh-inner">
                <h2 class="gh-container-title">{{t "Read more"}}</h2>
                <div class="gh-feed">
                    {{#foreach next}}
                        {{> "post-card" lazyLoad=true}}
                    {{/foreach}}
                </div>
            </div>
        </section>
    {{/if}}
{{/get}}
