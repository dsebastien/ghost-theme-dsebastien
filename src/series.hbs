{{!< default}}
{{!-- /series/ index (articles plan Tier 2.5). Lists every series with its
     ordered parts, reusing the series-strip renderer (currentId="" so no part
     is marked current). Driven by the same per-series list as series-nav.hbs;
     the `developassion-publish` skill maintains both between the markers. --}}

{{#contentFor "meta_description"}}
<meta name="description" content="All article series by Sebastien Dubois: multi-part guides on knowledge management, journaling, Git, TypeScript and more, in reading order.">
{{/contentFor}}

<main class="gh-main gh-outer series-index-page">
    <header class="!mt-24 gh-article-header gh-canvas hero">
        <h1 class="gh-article-title is-title text-center text-4xl font-bold">Series 📚</h1>
        <p class="text-4xl leading-relaxed max-w-4xl break-words text-center">Multi-part guides, in reading order.</p>
    </header>

    <div class="series-index-grid is-body">
        {{!-- SERIES-INDEX:START — developassion-publish inserts new series here.
             Order is pillar-priority: brand-central collections first, off-brand
             dev series last. Laid out as a responsive grid (1 col mobile ->
             2 -> 3 on larger desktops) via .series-index-grid. --}}
        {{> "components/series-strip" postsFilter="tag:hash-series-obsidian-deep-dives" seriesTitle="Obsidian deep dives" currentId="" onIndex=true}}
        {{> "components/series-strip" postsFilter="tag:hash-series-ai-workflows" seriesTitle="AI workflows" currentId="" onIndex=true}}
        {{> "components/series-strip" postsFilter="tag:hash-series-journaling" seriesTitle="Journaling every day is powerful" currentId="" onIndex=true}}
        {{> "components/series-strip" postsFilter="tag:hash-series-team-management" seriesTitle="Team management tips" currentId="" onIndex=true}}
        {{> "components/series-strip" postsFilter="tag:hash-series-git-tutorial" seriesTitle="Git tutorial for beginners" currentId="" onIndex=true}}
        {{> "components/series-strip" postsFilter="tag:hash-series-typescript" seriesTitle="What's new in TypeScript" currentId="" onIndex=true}}
        {{!-- SERIES-INDEX:END --}}
    </div>
</main>
