{{!< default}}
{{!--
    Guided-path template for the five layers of the Knowledge Master's Journey
    (homepage-start-overhaul Tier 2.3 / articles-page-overhaul Tier 3.3).

    Each /start/<layer>/ route binds a Ghost Page via `data: page.start-<layer>`
    (see configuration/routes.yaml). The data-source key is therefore `page`, so
    every field below is read inside {{#page}}...{{/page}}. The prose ({{content}})
    is Admin-editable — no redeploy needed to reword a layer.

    The layer-specific parts (article strips, the one contextual offer, and the
    prev/next-layer nav) are switched on the page slug with {{#match}}, the same
    pattern pillar-body.hbs uses. Order of the journey:
        start-foundation → start-system → start-practice
                          → start-application → start-creation
--}}
{{#page}}
{{#contentFor "meta_description"}}
<meta name="description" content="{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt characters="155"}}{{/if}}">
{{/contentFor}}

<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "{{title}}",
    {{#if custom_excerpt}}"description": "{{custom_excerpt}}",
    {{/if}}"url": "{{@site.url}}{{url}}",
    "isPartOf": { "@type": "WebSite", "name": "{{@site.title}}", "url": "{{@site.url}}" },
    "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{@site.url}}" },
            { "@type": "ListItem", "position": 2, "name": "Start Here", "item": "{{@site.url}}/start/" },
            { "@type": "ListItem", "position": 3, "name": "{{title}}" }
        ]
    }
}
</script>

<main class="gh-main start-page start-pillar-page">

    <!-- Hero -->
    <section class="gh-outer start-pillar-hero">
        <div class="gh-inner">
            <p class="pillar-kicker"><a href="/start/">Start Here</a> <span aria-hidden="true">›</span> Guided path</p>
            <p class="start-pillar-step">
                {{#match slug "start-foundation"}}Layer 1 of 5 · Foundation
                {{else match slug "start-system"}}Layer 2 of 5 · System
                {{else match slug "start-practice"}}Layer 3 of 5 · Practice
                {{else match slug "start-application"}}Layer 4 of 5 · Application
                {{else match slug "start-creation"}}Layer 5 of 5 · Creation
                {{/match}}
            </p>
            <h1 class="pillar-title is-title">{{title}}</h1>
            {{#if custom_excerpt}}
                <p class="pillar-intro is-body">{{custom_excerpt}}</p>
            {{/if}}
        </div>
    </section>

    <!-- Admin-editable prose (what you'll learn, quick win, who it's for) -->
    {{#if content}}
        <section class="gh-content gh-canvas is-body start-pillar-content">
            {{content}}
        </section>
    {{/if}}

    <!-- Essential reads for this layer -->
    <section class="gh-outer start-pillar-strips">
        <div class="gh-inner">
            <h2 class="gh-container-title">Essential reads for this layer</h2>
            <section class="home-strips">
                {{#match slug "start-foundation"}}
                    {{> "components/topic-section" title="" anchor="sp-foundation-feed"
                        topicFilter="tag:hash-pillar-pkm-foundations+tag:blog"
                        seeAllUrl="/pillars/pkm-foundations/" limit=6}}
                {{else match slug "start-system"}}
                    {{> "components/topic-section" title="" anchor="sp-system-feed"
                        topicFilter="tag:hash-pillar-tools-and-systems+tag:blog"
                        seeAllUrl="/pillars/tools-and-systems/" limit=6}}
                {{else match slug "start-practice"}}
                    {{> "components/topic-section" title="" anchor="sp-practice-feed"
                        topicFilter="tag:hash-pillar-writing-and-thinking+tag:blog"
                        seeAllUrl="/pillars/writing-and-thinking/" limit=6}}
                {{else match slug "start-application"}}
                    {{> "components/topic-section" title="Knowledge at work" anchor="sp-application-work-feed"
                        topicFilter="tag:hash-pillar-knowledge-work+tag:blog"
                        seeAllUrl="/pillars/knowledge-work/" limit=3}}
                    {{> "components/topic-section" title="Zen productivity &amp; balance" anchor="sp-application-balance-feed"
                        topicFilter="tag:hash-pillar-zen-productivity+tag:blog"
                        seeAllUrl="/pillars/zen-productivity/" limit=3}}
                {{else match slug "start-creation"}}
                    {{> "components/topic-section" title="Content systems" anchor="sp-creation-content-feed"
                        topicFilter="tag:hash-pillar-content-systems+tag:blog"
                        seeAllUrl="/pillars/content-systems/" limit=3}}
                    {{> "components/topic-section" title="AI &amp; creator systems" anchor="sp-creation-ai-feed"
                        topicFilter="tag:hash-pillar-creator-systems+tag:blog"
                        seeAllUrl="/pillars/creator-systems/" limit=3}}
                {{/match}}
            </section>
        </div>
    </section>

    <!-- One contextual offer for this layer -->
    <section class="gh-outer pillar-offer-band">
        <div class="gh-inner">
            {{#match slug "start-foundation"}}
                {{> "components/offer-card" topic="start-foundation"
                    heading="Ready to go deeper? Get the complete foundation in 10+ hours instead of weeks of scattered reading:"
                    productEmoji="📚" productName="Knowledge Management for Beginners"
                    productDesc="Structured video lessons — from information chaos to a working system."
                    productUrl="https://knowledge-management-for-beginners.com"
                    productId="knowledge-management-for-beginners" productPrice="€69.99"
                    magnetName="Knowledge System Checklist"
                    magnetUrl="https://www.dsebastien.net/free-knowledge-management-system-checklist"}}
            {{else match slug "start-system"}}
                {{> "components/offer-card" topic="start-system"
                    heading="Ready to go deeper? The Obsidian Starter Kit gets you to a working system in minutes, not months:"
                    productEmoji="🚀" productName="Obsidian Starter Kit"
                    productDesc="Ready-made vault, 40+ templates, proven structure, automation — save 100+ hours of trial and error."
                    productUrl="https://store.dsebastien.net/product/obsidian-starter-kit"
                    productId="obsidian-starter-kit" productPrice="€199.99-€249.99"
                    magnetName="Beginner's Guide to Obsidian"
                    magnetUrl="https://www.dsebastien.net/free-beginners-guide-to-mastering-obsidian"}}
            {{else match slug "start-practice"}}
                {{> "components/offer-card" topic="start-practice"
                    heading="Ready to go deeper? A note-taking practice that compounds:"
                    productEmoji="📓" productName="Journaling Deep Dive"
                    productDesc="Workshop on journaling, periodic reviews, and reflection routines."
                    productUrl="https://store.dsebastien.net/product/journaling-deep-dive"
                    productId="journaling-deep-dive" productPrice="€29.99"
                    magnetName="PKM Tools Database"
                    magnetUrl="https://www.dsebastien.net/free-pkm-tools-database"}}
            {{else match slug "start-application"}}
                {{> "components/offer-card" topic="start-application"
                    heading="Ready to go deeper? Systems for professional knowledge workers:"
                    productEmoji="💼" productName="Knowledge Worker Kit"
                    productDesc="Comprehensive guides and proven systems to leverage knowledge in your career — organize the business in your head."
                    productUrl="https://store.dsebastien.net/product/knowledge-worker-kit"
                    productId="knowledge-worker-kit" productPrice="€249.99"
                    magnetName="Knowledge System Checklist"
                    magnetUrl="https://www.dsebastien.net/free-knowledge-management-system-checklist"}}
            {{else match slug "start-creation"}}
                {{> "components/offer-card" topic="start-creation"
                    heading="Ready to go deeper? Make AI write like you — your voice, your context, your standards:"
                    productEmoji="🤖" productName="AI Ghostwriter Guide"
                    productDesc="Turn your knowledge into publish-ready content, in your own voice."
                    productUrl="https://store.dsebastien.net/product/ai-ghostwriter-guide"
                    productId="ai-ghostwriter-guide" productPrice="€49.99"
                    magnetName="Knowledge System Checklist"
                    magnetUrl="https://www.dsebastien.net/free-knowledge-management-system-checklist"}}
            {{/match}}
        </div>
    </section>

    <!-- Prev / next layer nav -->
    <section class="gh-outer start-pillar-nav-band">
        <div class="gh-inner">
            <nav class="start-pillar-nav" aria-label="Guided path navigation">
                {{#match slug "start-foundation"}}
                    <span class="start-pillar-nav-spacer"></span>
                    <a class="start-pillar-nav-next" href="/start/system/"><span class="start-pillar-nav-dir">Next layer ›</span><span class="start-pillar-nav-name">System — build your command center</span></a>
                {{else match slug "start-system"}}
                    <a class="start-pillar-nav-prev" href="/start/foundation/"><span class="start-pillar-nav-dir">‹ Previous</span><span class="start-pillar-nav-name">Foundation</span></a>
                    <a class="start-pillar-nav-next" href="/start/practice/"><span class="start-pillar-nav-dir">Next layer ›</span><span class="start-pillar-nav-name">Practice — turn information into insight</span></a>
                {{else match slug "start-practice"}}
                    <a class="start-pillar-nav-prev" href="/start/system/"><span class="start-pillar-nav-dir">‹ Previous</span><span class="start-pillar-nav-name">System</span></a>
                    <a class="start-pillar-nav-next" href="/start/application/"><span class="start-pillar-nav-dir">Next layer ›</span><span class="start-pillar-nav-name">Application — leverage it at work</span></a>
                {{else match slug "start-application"}}
                    <a class="start-pillar-nav-prev" href="/start/practice/"><span class="start-pillar-nav-dir">‹ Previous</span><span class="start-pillar-nav-name">Practice</span></a>
                    <a class="start-pillar-nav-next" href="/start/creation/"><span class="start-pillar-nav-dir">Next layer ›</span><span class="start-pillar-nav-name">Creation — turn knowledge into output</span></a>
                {{else match slug "start-creation"}}
                    <a class="start-pillar-nav-prev" href="/start/application/"><span class="start-pillar-nav-dir">‹ Previous</span><span class="start-pillar-nav-name">Application</span></a>
                    <a class="start-pillar-nav-next" href="https://www.dsebastien.net/join-the-knowii-community-and-fix-your-information-overload-problem/"><span class="start-pillar-nav-dir">Master all five ›</span><span class="start-pillar-nav-name">Join the Knowii Community</span></a>
                {{/match}}
            </nav>
            <p class="start-pillar-nav-home"><a href="/start/">↑ Back to the full journey</a></p>
        </div>
    </section>

</main>
{{/page}}
