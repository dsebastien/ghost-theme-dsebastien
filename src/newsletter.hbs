{{!< default}}
{{!-- The tag above means: insert everything in this file into the body of the default.hbs template --}}

{{#contentFor "meta_description"}}
<meta name="description" content="DeveloPassion's Newsletter by Sébastien Dubois. A weekly letter about knowledge work, AI, productivity, and building knowledge systems that compound.">
{{/contentFor}}

<main class="gh-main gh-outer newsletter-page">

        <header class="gh-article-header gh-canvas">
            <h1 class="gh-article-title is-title text-center text-4xl font-bold mt-8 mb-4">
                DeveloPassion's Newsletter 💌
            </h1>
        </header>

            <section class="gh-content gh-canvas is-body">

                {{!-- Logged-out users: hero + free subscribe pitch --}}
                {{#unless @member}}
                    <!-- Hero -->
                    <section class="hero !mt-0">
                        <h2>Turn Information Overload into Clear Thinking</h2>
                        <p class="max-w-xl mx-auto">Every week, I share practical systems, tools, and frameworks to help you organize your knowledge, leverage AI, and create consistently. No fluff. No spam.</p>
                        <p class="hero-social-proof">{{@custom.stat_newsletter_members}} readers already subscribed ✨</p>
                    </section>

                    <!-- Subscribe form -->
                    <section class="cta-newsletter">
                        <h2>Subscribe for free 💌</h2>
                        {{> "email-subscription" email_field_id="newsletter-email"}}
                    </section>
                {{/unless}}

                {{!-- Tier comparison: visible to EVERYONE — logged-in free members
                     are the warmest upgrade audience; only the Free card is
                     redundant for them. --}}
                <section class="newsletter-tiers">
                    <h3>{{#if @member}}Go further{{else}}Membership tiers{{/if}}</h3>
                    <div class="newsletter-tiers-grid">
                        {{#unless @member}}
                        <div class="newsletter-tier">
                            <h4>Free</h4>
                            <ul>
                                <li>✅ New newsletter editions in your inbox</li>
                                <li>✅ All articles &amp; the full archive</li>
                            </ul>
                            <a href="#/portal/signup" data-portal="signup" class="gh-button newsletter-tier-cta">Subscribe free →</a>
                        </div>
                        {{/unless}}
                        {{#unless @member.paid}}
                        <div class="newsletter-tier">
                            <h4>Supporter</h4>
                            <ul>
                                <li>✅ Everything in Free</li>
                                <li>✅ Exclusive discounts</li>
                                <li>✅ Early access to products</li>
                                <li>✅ Support my work as a creator 🌹</li>
                            </ul>
                            <a href="#/portal/signup" data-portal="{{#if @member}}upgrade{{else}}signup{{/if}}" class="gh-button newsletter-tier-cta">Become a Supporter →</a>
                        </div>
                        {{/unless}}
                        <div class="newsletter-tier newsletter-tier-highlight">
                            <span class="newsletter-tier-badge">RECOMMENDED</span>
                            <h4>Knowii Community</h4>
                            <ul>
                                <li>✅ A private community of knowledge workers</li>
                                <li>✅ Everything in Free, plus workshops, courses &amp; tools — depending on the tier you pick</li>
                                <li>✅ Up to €700+ of my products &amp; courses included</li>
                                <li>✅ <span data-price="knowii-community">From €14.99/quarter</span></li>
                            </ul>
                            <a href="https://www.store.dsebastien.net/product/knowii-community" rel="noopener" class="gh-button newsletter-tier-cta">Join Knowii →</a>
                        </div>
                    </div>
                </section>

            </section>

        <section class="gh-container is-grid has-sidebar gh-outer">
            <div class="gh-container-inner gh-inner">
                <main class="gh-main">
                    <!-- Recent Editions -->
                    <h2 class="!mt-0 section-title">Recent Editions</h2>
                    <p>📡 <a class="top-link" href="/newsletter/rss/">Subscribe to the newsletter archive RSS feed</a> · <a class="top-link" href="/feeds/">browse all feeds</a>.</p>
                    <div class="gh-feed mt-4">
                        {{#get "posts" filter="tag:newsletter" include="tags" limit=12 as |recent|}}
                            {{#foreach recent}}
                                {{> "post-card"}}
                            {{/foreach}}
                        {{/get}}

                        <div class="">
                            <a href="/tag/newsletter">See More {{> "icons/arrow"}}</a>
                            <hr class="!my-8"/>
                        </div>
                    </div>
                </main>

                {{> "components/sidebar" showFeatured=true showCategories=true showRecommendations=false}}
            </div>
        </section>
</main>
