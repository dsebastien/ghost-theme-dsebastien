{{!< default}}
{{!-- The tag above means: insert everything in this file into the body of the default.hbs template --}}
{{!-- Channel: /all-articles/ (filter: tag:blog — see configuration/routes.yaml).
     Utility crawl index for maintenance and search engines: a plain, complete,
     natively-paginated list of every article. Deliberately not a showcase. --}}

{{#contentFor "meta_description"}}
<meta name="description" content="Browse every article by Sébastien Dubois. Knowledge management, productivity, AI, software, and personal development, indexed in one place.">
{{/contentFor}}

<main class="gh-main gh-outer all-articles-page">
    <header class="!mt-24 gh-article-header gh-canvas hero">
        <h1 class="gh-article-title is-title text-center text-4xl font-bold">
            All Articles ✍️
        </h1>
        <p class="text-4xl leading-relaxed max-w-4xl break-words text-center">{{pagination.total}} articles and counting... 🎉</p>
    </header>

    <section class="gh-content gh-canvas is-body">
        <ul class="!mx-8 space-y-4 text-2xl">
            {{#foreach posts}}
                <li class="border-b border-gray-200 py-4">
                    <article>
                        <h2 class="text-2xl font-semibold !mb-2">
                            <a href="{{url}}" class="capitalize">{{title}}</a>
                        </h2>

                        <div class="text-md text-gray-500">
                            <time datetime="{{date format="YYYY-MM-DD"}}">
                                {{date format="MMMM DD, YYYY"}}
                            </time>
                            {{!-- tags.[0] is the content-type marker (blog); tags.[1] is the first topic tag --}}
                            {{#if tags.[1]}}
                                <span>&middot;&nbsp;</span>
                                <a href="{{tags.[1].url}}" class="hover:text-primary transition-colors capitalize">{{tags.[1].name}}</a>
                            {{/if}}
                        </div>
                    </article>
                </li>
            {{/foreach}}
        </ul>

        {{pagination}}
    </section>
</main>
