{{!< default}}
{{!-- The tag above means: insert everything in this file into the body of the default.hbs template --}}
{{!-- Channel: /all-articles/ (filter: tag:blog — see configuration/routes.yaml).
     Complete, natively-paginated index of every article. Now a scannable card
     grid with the shared sidebar (About + Knowii + Featured), mirroring /blog/'s
     layout — still crawler-complete, just no longer a bare text list. --}}

{{#contentFor "meta_description"}}
<meta name="description" content="Browse every article by Sébastien Dubois. Knowledge management, productivity, AI, software, and personal development, indexed in one place.">
{{/contentFor}}

{{> "schema/collection" pageName="All Articles" pageDesc="Every article by Sébastien Dubois, indexed in one place." path="/all-articles/" sectionName="Articles" sectionPath="/blog/" itemsFilter="tag:blog"}}

<main class="gh-main gh-outer all-articles-page">
    <header class="!mt-24 gh-article-header gh-canvas hero">
        <h1 class="gh-article-title is-title text-center text-4xl font-bold">
            All Articles ✍️
        </h1>
        <p class="text-4xl leading-relaxed max-w-4xl break-words text-center">{{pagination.total}} articles and counting... 🎉</p>
    </header>

    <section class="gh-container is-grid has-sidebar gh-outer">
        <div class="gh-container-inner gh-inner">
            <main class="gh-main">
                <div class="gh-feed">
                    {{#foreach posts}}
                        {{> "post-card" lazyLoad=true}}
                    {{/foreach}}
                </div>

                {{pagination}}
            </main>

            {{> "components/sidebar" showFeatured=true}}
        </div>
    </section>
</main>
