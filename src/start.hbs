                    <section class="home-strips">
                        {{> "components/topic-section"
                            title="Content Systems"
                            anchor="start-creation-content-feed"
                            topicFilter="tag:hash-pillar-content-systems+tag:blog"
                            seeAllUrl="/pillars/content-systems/"
                            limit=3}}

                        {{> "components/topic-section"
                            title="AI and Creator Systems"
                            anchor="start-creation-ai-feed"
                            topicFilter="tag:hash-pillar-creator-systems+tag:blog"
                            seeAllUrl="/pillars/creator-systems/"
