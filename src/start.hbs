{{!< default}}
{{!-- The tag above means: insert everything in this file into the body of the default.hbs template --}}

{{#contentFor "meta_description"}}
<meta name="description" content="New here? Start with Sébastien Dubois's best resources on knowledge management, productivity, AI, and building reliable creator systems.">
{{/contentFor}}

<main class="gh-main start-page">
    <article class="gh-article">
        <header class="gh-article-header gh-canvas">
            <h1 class="gh-article-title is-title !text-center">Your Operating System for Knowledge Mastery</h1>
        </header>

        <section class="gh-content gh-canvas is-body">
            <!-- Hero -->
            <section class="hero">
                <p>Five areas that build on each other, turning information chaos into a complete creator system. Each layer strengthens the next, so your knowledge compounds over time.</p>

                <div class="hero-stats">
                    <span>{{@custom.stat_newsletter_members}} newsletter members</span>
                    <span class="stat-separator">&bull;</span>
                    <span>{{@custom.stat_years_expertise}} years expertise</span>
                    <span class="stat-separator">&bull;</span>
                    <span>{{@custom.stat_community_members}} community members</span>
                </div>

                {{> "components/path-router" variant="start"}}
            </section>

            <!-- Builder OS Framework Visual -->
            <section class="builder-os-visual">
                <h2>The Five Layers of Knowledge Mastery</h2>
                <div class="layer-stack">
                    <div class="layer-bar layer-creation">
                        <span class="layer-bar-name">Creation</span>
                        <span class="layer-bar-desc">Turn knowledge into content, products, and impact</span>
                    </div>
                    <div class="layer-bar layer-application">
                        <span class="layer-bar-name">Application</span>
                        <span class="layer-bar-desc">Leverage knowledge at work and in life</span>
                    </div>
                    <div class="layer-bar layer-practice">
                        <span class="layer-bar-name">Practice</span>
                        <span class="layer-bar-desc">Transform raw information into connected insights</span>
                    </div>
                    <div class="layer-bar layer-system">
                        <span class="layer-bar-name">System</span>
                        <span class="layer-bar-desc">Build your tools and organizational frameworks</span>
                    </div>
                    <div class="layer-bar layer-foundation">
                        <span class="layer-bar-name">Foundation</span>
                        <span class="layer-bar-desc">Understand why knowledge management matters</span>
                    </div>
                </div>
                <p class="builder-os-note">Builder OS is the complete creator operating system I'm building. Each area below gives you free resources and accelerators to master that layer.</p>
                <p class="builder-os-cta">Want the complete system? <a href="https://www.dsebastien.net/join-the-knowii-community-and-fix-your-information-overload-problem/">Join the Knowii Community</a></p>
