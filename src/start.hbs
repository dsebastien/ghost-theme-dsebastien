                <h2>Your Knowledge Mastery Timeline</h2>
                <div class="timeline">
                    <div class="timeline-point">
                        <span class="time">Week 1-2</span>
                        <span class="milestone">Foundation</span>
                    </div>
                    <div class="timeline-point">
                        <span class="time">Week 3-4</span>
                        <span class="milestone">System</span>
                    </div>
                    <div class="timeline-point">
                        <span class="time">Month 2</span>
                        <span class="milestone">Practice</span>
