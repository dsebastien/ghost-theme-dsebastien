                        <a href="https://www.dsebastien.net/join-the-knowii-community-and-fix-your-information-overload-problem/" class="btn-product">Get Early Access &rarr;</a>
                    </div>

                    {{> "components/offer-card" topic="start-creation"
                        heading="Ready to go deeper? Turn AI into your personal writing assistant:"
                        productEmoji="🤖" productName="AI Ghostwriter Guide"
                        productDesc="Make AI write like you — your voice, your context, your standards."
                        productUrl="https://store.dsebastien.net/product/ai-ghostwriter-guide"
