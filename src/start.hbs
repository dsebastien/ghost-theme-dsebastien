                    <section class="home-strips">
                        {{> "components/topic-section"
                            title=""
                            anchor="start-system-feed"
                            topicFilter="tag:hash-pillar-tools-and-systems+tag:blog"
                            seeAllUrl="/pillars/tools-and-systems/"
                            limit=6}}
                    </section>

                    <!-- Testimonial: Julien Dambron -->
                    <div class="success-story">
                        <blockquote>
                            <p>"Superbly crafted material that consistently grows and improves with time, demonstrating a relentless commitment to excellence and constant refinement."</p>
                            <footer>
                                <strong>Julien Dambron</strong>
                                <span class="result">Experienced continuous improvement over time</span>
                            </footer>
